# OpenAI：用于跨来源语义去重、中文摘要、分类和重要性排序
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# 飞书“AI 增长内部群”中的 V2 自定义机器人
FEISHU_WEBHOOK_URL=
# 如果机器人启用了“签名校验”，填写对应密钥；否则留空
FEISHU_SIGNING_SECRET=

# 本地运行时可选；GitHub Actions 会自动提供 GITHUB_TOKEN
GITHUB_TOKEN=

TARGET_NEWS_COUNT=10
LOOKBACK_HOURS=36
MAX_CANDIDATES=80
STATE_PATH=.state/history.json

